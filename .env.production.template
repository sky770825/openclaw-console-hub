# .env.production.template
# 生產環境環境變數範例

# --- 一般設定 ---
NODE_ENV=production
PORT=8080

# --- 安全性與 CORS ---
# 允許跨網域請求的來源 (用逗號分隔)
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,https://admin-dashboard.com
# 強制啟用寫入權限驗證 (true/false)
FORCE_WRITE_AUTH=true

# --- 資料庫設定 (Railway / Supabase / MongoDB) ---
DATABASE_URL=postgresql://user:password@host:port/dbname
# 如果是 MongoDB
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# --- API Keys & Secrets ---
# 用於 JWT 或 Session 的密鑰
APP_SECRET=your_long_random_secret_string_here
# 其他外部服務 API Key
OPENAI_API_KEY=sk-proj-xxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxx

# --- 部署平台特定變數 ---
# Railway 提供的自動變數通常不需要手動填寫
# Vercel 部署前端時，NEXT_PUBLIC_ 前綴的變數會暴露給瀏覽器
NEXT_PUBLIC_API_URL=https://your-backend-api.railway.app
