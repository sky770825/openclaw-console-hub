# 環境變數範本
# 複製此檔案為 .env 並填入您的設定

# Facebook 設定
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_APP_ID=

# Instagram 設定
INSTAGRAM_ACCOUNT_ID=
