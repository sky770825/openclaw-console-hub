      "credentials": {
        "qdrantApi": {
          "id": "YOUR_QDRANT_CREDENTIAL_ID",
          "name": "Qdrant account"
        }
      }
    },
    {
      "parameters": {
        "jsMode": "expression",
        "jsCode": "const conversation = $input.all()[0].json;\nconst userMessage = conversation.userMessage || conversation.body?.message || JSON.stringify(conversation);\nconst aiResponse = conversation.aiResponse || '回應內容';\n\n// 組合要儲存的記憶內容\nconst memoryContent = `用戶: ${userMessage}\nAI: ${aiResponse}\n時間: ${new Date().toISOString()}`;\n\nreturn [{\n  json: {\n    pageContent: memoryContent,\n    metadata: {\n      timestamp: new Date().toISOString(),\n      sessionId: conversation.sessionId || 'default',\n      type: 'conversation'\n    }\n  }\n}];"
      },
      "id": "code-prepare-memory-1",
      "name": "Prepare Memory Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        650,
        300
      ]
    },
