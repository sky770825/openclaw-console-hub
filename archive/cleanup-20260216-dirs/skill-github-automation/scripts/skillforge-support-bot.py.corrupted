# Ollama API 氓庐垄忙聢露莽芦炉
# ============================================================================
import http.client
import json

class OllamaClient:
    def __init__(self, host, port, model):
        self.host = host
        self.port = port
        self.model = model
    
    def generate(self, prompt: str, system: str = "") -> str:
        """氓聭录氓聫芦 Ollama 莽聰聼忙聢聬氓聸聻猫娄聠"""
        try:
            post_data = json.dumps({
                "model": self.model,
                "prompt": prompt,
                "system": system or PRODUCT_CONTEXT,
                "stream": False,
                "options": {
                    "temperature": 0.7,
                    "num_predict": 500
                }
            })
            
            conn = http.client.HTTPConnection(self.host, self.port, timeout=60)
            conn.request("POST", "/api/generate", post_data, {
                "Content-Type": "application/json"
            })
            
            response = conn.getresponse()
            data = response.read().decode()
            conn.close()
            
            result = json.loads(data)
            return result.get("response", "忙聤卤忙颅聣茂录聦忙聢聭莽聞隆忙鲁聲氓聸聻莽颅聰茅聙聶氓聙聥氓聲聫茅隆聦茫聙聜")
        except Exception as e:
            logger.error(f"Ollama 茅聦炉猫陋陇: {e}")
            return "冒聼陇聰 忙聤卤忙颅聣茂录聦忙聢聭忙職芦忙聶聜莽聞隆忙鲁聲猫聶聲莽聬聠茅聙聶氓聙聥氓聲聫茅隆聦茫聙聜猫芦聥猫聛炉莽鹿芦盲潞潞氓路楼氓庐垄忙聹聧 @gousmaaa 莽聧虏氓戮聴氓聧聰氓聤漏茫聙聜"
    
    def check_health(self) -> bool:
        """忙陋垄忙聼楼 Ollama 忙聵炉氓聬娄茅聛聥猫隆聦盲赂颅"""
        try:
            conn = http.client.HTTPConnection(self.host, self.port, timeout=5)
            conn.request("GET", "/api/tags")
            response = conn.getresponse()
            conn.close()
            return response.status == 200
        except:
            return False

