        await update.message.reply_text("芒聹聟 氓路虏忙聰露氓聢掳盲陆聽莽職聞盲禄聵忙卢戮忙聢陋氓聹聳茂录聛忙颅拢氓聹篓猫聶聲莽聬聠盲赂颅茂录聦猫芦聥莽篓聧氓聙聶...")
        
        # 茅聙聶猫拢隆忙聡聣猫漏虏氓聤聽氓聟楼盲禄聵忙卢戮茅漏聴猫颅聣茅聜聫猫录炉 (盲戮聥氓娄聜氓聭录氓聫芦 Tronscan API 忙聼楼猫漏垄 TxID)
        # 莽聜潞盲潞聠忙录聰莽陇潞茂录聦茅聙聶猫拢隆莽聸麓忙聨楼氓聛聡猫篓颅盲禄聵忙卢戮忙聢聬氓聤聼
        payment_verified = True # 氓聛聡猫篓颅盲禄聵忙卢戮氓路虏茅漏聴猫颅聣
        
        if payment_verified:
            # 莽聰垄莽聰聼 License Key
            license_key = self.license_manager.generate_license(
                tier=selected_tier, 
                user_id=str(user_id), 
                user_email=user_email
            )
            
            # 氓聬聦忙颅楼氓聢掳 Supabase
            # 茅聙聶猫拢隆茅聹聙猫娄聛氓掳聡 license_manager 猫聢聡 SupabaseManager 忙聲麓氓聬聢茂录聦忙聢聳莽聸麓忙聨楼氓聹篓 LicenseManager 氓聟搂茅聝篓猫聶聲莽聬聠 Supabase 氓聬聦忙颅楼
            # 忙職芦忙聶聜莽聸麓忙聨楼氓聭录氓聫芦 Supabase 茅聙虏猫隆聦 upsert
            supabase_payload = {
                "license_key": license_key,
                "tier": selected_tier,
                "status": "active",
                "created_at": datetime.now().isoformat(),
                "expires_at": (datetime.now() + timedelta(days=365)).isoformat(),
                "user_id": str(user_id),
                "user_email": user_email,
                "max_activations": 5 if selected_tier == "enterprise" else 1,
                "updated_at": datetime.now().isoformat()
            }
            response = self.supabase.table('licenses').upsert(supabase_payload, on_conflict='license_key').execute()
            
            if response.data:
                await update.message.reply_text(
                    f"冒聼聨聣 忙聛颅氓聳聹盲陆聽茂录聛盲陆聽莽職聞 {selected_tier.upper()} 莽聣聢 License Key 氓路虏莽聰聼忙聢聬茂录聛\n\n"
                    f"冒聼聰聭 **License Key**: `{license_key}`\n\n"
                    f"冒聼職聙 **氓庐聣猫拢聺猫陋陋忙聵聨**茂录職\n"
                    "`npm install ./skillforge-github-automation-1.0.0.tgz`\n"
                    f"莽聞露氓戮聦盲陆驴莽聰篓忙颅陇 License Key 氓聢聺氓搂聥氓聦聳 SkillForge茫聙聜\n\n"
                    f"冒聼聰聮 **忙漏聼氓聶篓莽露聛氓庐職忙聫聬茅聠聮**茂录職茅娄聳忙卢隆盲陆驴莽聰篓忙聹聝猫聡陋氓聥聲莽露聛氓庐職忙颅陇茅聸禄猫聟娄茫聙聜忙聫聸茅聸禄猫聟娄猫芦聥猫聛炉莽鹿芦氓庐垄忙聹聧猫搂拢茅聶陇莽露聛氓庐職茫聙聜\n\n"
                    f"冒聼聯搂 License Key 氓路虏莽聶录茅聙聛猫聡鲁盲陆聽莽職聞 Email: `{user_email}`茂录聦猫芦聥忙聼楼忙聰露茂录聛\n\n"
                    "忙聞聼猫卢聺盲陆聽莽職聞猫鲁录猫虏路茂录聛"
                )
                logger.info(f"芒聹聟 莽聰篓忙聢露 {user_id} ({user_email}) 猫鲁录猫虏路 {selected_tier} 莽聣聢忙聢聬氓聤聼茂录聦License Key: {license_key}")
                # 忙赂聟茅聶陇莽聰篓忙聢露莽聥聙忙聟聥
                context.user_data['state'] = None
                context.user_data['purchase_email'] = None
                context.user_data['purchase_tier'] = None
            else:
                logger.error(f"芒聺聦 Supabase upsert 氓陇卤忙聲聴: {response.error}")
                await update.message.reply_text("芒聺聦 莽聶录莽聰聼茅聦炉猫陋陇茂录聦莽聞隆忙鲁聲莽聰聼忙聢聬 License Key茫聙聜猫芦聥猫聛炉莽鹿芦盲潞潞氓路楼氓庐垄忙聹聧 @gousmaaa")
        else:
            await update.message.reply_text("芒聺聦 盲禄聵忙卢戮茅漏聴猫颅聣氓陇卤忙聲聴茫聙聜猫芦聥莽垄潞盲驴聺忙聢陋氓聹聳忙赂聟忙聶掳茂录聦盲赂娄氓聦聟氓聬芦氓庐聦忙聲麓莽職聞盲潞陇忙聵聯猫鲁聡猫篓聤茫聙聜氓娄聜忙聻聹氓聲聫茅隆聦忙聦聛莽潞聦茂录聦猫芦聥猫聛炉莽鹿芦盲潞潞氓路楼氓庐垄忙聹聧 @gousmaaa")
        
        # 忙赂聟茅聶陇莽聰篓忙聢露莽聥聙忙聟聥 (盲赂聧猫芦聳忙聢聬氓聤聼忙聢聳氓陇卤忙聲聴茂录聦猫庐聯莽聰篓忙聢露氓聫炉盲禄楼茅聡聧忙聳掳茅聳聥氓搂聥)
        context.user_data['state'] = None
        context.user_data['purchase_email'] = None
        context.user_data['purchase_tier'] = None


    async def handle_message(self, update: Update, context: ContextTypes.DEFAULT_TYPE):
        """猫聶聲莽聬聠盲赂聙猫聢卢猫篓聤忙聛炉"""
        if not update.message or not update.message.text and not update.message.photo:
            return
        
        user_id = update.effective_user.id
        user_state = context.user_data.get('state')

        # 猫聶聲莽聬聠猫鲁录猫虏路忙碌聛莽篓聥莽職聞莽聥聙忙聟聥
        if user_state == 'awaiting_email':
            return await self.handle_email_input(update, context)
        elif user_state == 'awaiting_version_selection':
            # 氓娄聜忙聻聹忙聵炉氓聹聳莽聣聡茂录聦氓聣聡猫聶聲莽聬聠盲禄聵忙卢戮忙聢陋氓聹聳
            if update.message.photo:
                return await self.handle_payment_proof(update, context)
            else:
                await update.message.reply_text("猫芦聥莽聶录茅聙聛**盲禄聵忙卢戮盲潞陇忙聵聯忙聢陋氓聹聳**茂录聦猫聙聦盲赂聧忙聵炉忙聳聡氓颅聴茫聙聜")
                return

        # 猫聶聲莽聬聠忙聶庐茅聙職猫篓聤忙聛炉
        text = update.message.text.strip()
        if text.startswith('/'):
            return
        
        user = update.effective_user
        self.stats["total"] += 1
        logger.info(f"冒聼聭陇 {user.username or user.first_name}: {text[:50]}")
        
        # 莽聶录茅聙聛茫聙聦忙聙聺猫聙聝盲赂颅茫聙聧忙聫聬莽陇潞
        await context.bot.send_chat_action(
            chat_id=update.effective_chat.id,
            action="typing"
        )
        
        # 莽聰聼忙聢聬氓聸聻猫娄聠
        reply = await self.generate_reply(text)
        
        # 莽聶录茅聙聛氓聸聻猫娄聠
        await update.message.reply_text(reply, reply_markup=self.get_main_menu()) # 忙炉聫忙卢隆氓聸聻猫娄聠氓戮聦茅聝陆茅隆炉莽陇潞盲赂禄茅聛赂氓聳庐
        
        if "莽聞隆忙鲁聲猫聶聲莽聬聠" not in reply:
            self.stats["success"] += 1
            logger.info("冒聼陇聳 AI 氓聸聻猫娄聠忙聢聬氓聤聼")
        else:
            self.stats["failed"] += 1
            logger.info("芒聺聦 猫陆聣盲潞潞氓路楼")
    
    async def error_handler(self, update: object, context: ContextTypes.DEFAULT_TYPE):
        """茅聦炉猫陋陇猫聶聲莽聬聠"""
        logger.error(f"猫聶聲莽聬聠忙聸麓忙聳掳忙聶聜莽聶录莽聰聼茅聦炉猫陋陇: {context.error}", exc_info=context.error)

# ============================================================================
# 盲赂禄莽篓聥氓录聫
# ============================================================================
def main():
    bot = SkillForgeBot()
    
    # 忙陋垄忙聼楼 Ollama
    if not bot.ollama.check_health():
        logger.error("芒聺聦 Ollama 忙聹陋氓聲聼氓聥聲忙聢聳莽聞隆忙鲁聲茅聙拢莽路職")
        logger.error(f"   猫芦聥莽垄潞猫陋聧 Ollama 忙颅拢氓聹篓茅聛聥猫隆聦: http://{OLLAMA_HOST}:{OLLAMA_PORT}")
        sys.exit(1)
    
    logger.info(f"芒聹聟 Ollama 茅聙拢莽路職忙颅拢氓赂赂 (盲陆驴莽聰篓忙篓隆氓聻聥: {OLLAMA_MODEL})")
    
    # 氓禄潞莽芦聥 Application
    app = Application.builder().token(BOT_TOKEN).build()
    
    # 猫篓禄氓聠聤 handlers
    app.add_handler(CommandHandler("start", bot.cmd_start))
    app.add_handler(CallbackQueryHandler(bot.handle_callback, pattern=re.compile(r"^(?!buy_).+$"))) # 忙聨聮茅聶陇 buy_ 茅聳聥茅聽颅莽職聞 callback
    app.add_handler(CallbackQueryHandler(bot.handle_version_selection, pattern=re.compile(r"^buy_"))) # 猫聶聲莽聬聠 buy_ 茅聳聥茅聽颅莽職聞 callback
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, bot.handle_message))
    app.add_handler(MessageHandler(filters.PHOTO, bot.handle_message)) # 猫聶聲莽聬聠氓聹聳莽聣聡猫篓聤忙聛炉
    app.add_error_handler(bot.error_handler)
    
    logger.info("冒聼陇聳 SkillForge 氓庐垄忙聹聧忙漏聼氓聶篓盲潞潞氓路虏氓聲聼氓聥聲茂录聛")
    logger.info("冒聼聯隆 莽颅聣氓戮聟猫篓聤忙聛炉...\n")
    
    # 茅聳聥氓搂聥猫录陋猫漏垄
    app.run_polling(allowed_updates=Update.ALL_TYPES)

if __name__ == "__main__":
    main()