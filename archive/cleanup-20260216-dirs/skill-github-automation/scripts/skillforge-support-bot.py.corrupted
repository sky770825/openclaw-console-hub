    async def handle_email_input(self, update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
        """猫聶聲莽聬聠莽聰篓忙聢露猫录赂氓聟楼莽職聞 Email"""
        user_email = update.message.text.strip()
        user_id = update.effective_user.id

        if not re.match(r"[^@]+@[^@]+\.[^@]+", user_email):
            await update.message.reply_text("芒聹聣茂赂聫 Email 忙聽录氓录聫盲赂聧忙颅拢莽垄潞茂录聦猫芦聥茅聡聧忙聳掳猫录赂氓聟楼茫聙聜")
            return

        context.user_data['purchase_email'] = user_email
        context.user_data['state'] = 'awaiting_version_selection'

        keyboard = [
            [InlineKeyboardButton("冒聼楼聣 Lite (USDT $20)", callback_data="buy_lite")],
            [InlineKeyboardButton("冒聼楼聢 Pro (USDT $50 + $10/氓鹿麓)", callback_data="buy_pro")],
            [InlineKeyboardButton("冒聼楼聡 Enterprise (USDT $200 + $50/氓鹿麓)", callback_data="buy_enterprise")]
        ]
        reply_markup = InlineKeyboardMarkup(keyboard)
        await update.message.reply_text(
            f"芒聹聟 氓路虏忙聰露氓聢掳盲陆聽莽職聞 Email: {user_email}\n\n"
            "莽聫戮氓聹篓猫芦聥茅聛赂忙聯聡盲陆聽猫娄聛猫鲁录猫虏路莽職聞莽聣聢忙聹卢茂录職", reply_markup=reply_markup
        )
    
    async def handle_version_selection(self, update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
        """猫聶聲莽聬聠莽聰篓忙聢露茅聛赂忙聯聡莽職聞莽聣聢忙聹卢"""
        query = update.callback_query
        await query.answer()
        data = query.data
        user_id = query.from_user.id
        user_email = context.user_data.get('purchase_email')

        if not user_email:
            await query.edit_message_text("芒聺聦 猫鲁录猫虏路忙碌聛莽篓聥茅聦炉猫陋陇茂录聦猫芦聥茅聡聧忙聳掳茅聳聥氓搂聥茫聙聜")
            context.user_data['state'] = None
            return

        selected_tier = None
        price = 0
        if data == "buy_lite":
            selected_tier = "lite"
            price = 20
        elif data == "buy_pro":
            selected_tier = "pro"
            price = 50
        elif data == "buy_enterprise":
            selected_tier = "enterprise"
            price = 200
        
        if not selected_tier:
            await query.edit_message_text("芒聺聦 莽聞隆忙聲聢莽職聞莽聣聢忙聹卢茅聛赂忙聯聡茫聙聜")
            return

        context.user_data['purchase_tier'] = selected_tier
        context.user_data['state'] = 'awaiting_payment_proof'

        payment_info = (
            f"忙聜篓茅聛赂忙聯聡盲潞聠 **{selected_tier.upper()} 莽聣聢** (USDT ${price})茫聙聜\n\n"
            "猫芦聥氓掳聡 USDT (TRC-20 莽露虏猫路炉) 猫陆聣氓赂鲁猫聡鲁盲禄楼盲赂聥茅聦垄氓聦聟氓聹掳氓聺聙茂录職\n\n"
            "`TALc5eQifjsd4buSDRpgSiYAxUpLNoNjLD`\n\n"
            "芒職聽茂赂聫 **茅聡聧猫娄聛**茂录職猫芦聥氓聥聶氓驴聟盲陆驴莽聰篓 **TRC-20 莽露虏猫路炉**茂录聛茅聦炉猫陋陇莽露虏猫路炉忙聹聝氓掳聨猫聡麓猫鲁聡茅聡聭茅聛潞氓陇卤盲赂聰莽聞隆忙鲁聲茅聙聙氓聸聻茂录聛\n\n"
            "猫陆聣氓赂鲁氓庐聦忙聢聬氓戮聦茂录聦猫芦聥氓掳聡**盲禄聵忙卢戮盲潞陇忙聵聯忙聢陋氓聹聳**莽聶录茅聙聛莽碌娄忙聢聭茂录聢氓聦聟氓聬芦 TxID茂录聣茂录聦忙聢聭忙聹聝莽聜潞盲陆聽猫聶聲莽聬聠 License Key茂录聛"
