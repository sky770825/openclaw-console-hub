# OpenRouter API Key
# 获取地址: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# SeekDB 数据库配置
SEEKDB_HOST=127.0.0.1
SEEKDB_PORT=2881
SEEKDB_USER=root
SEEKDB_PASSWORD=
SEEKDB_DATABASE=test

# 可选: Embedding 模型选择
# qwen/qwen3-embedding-8b (高质量, 1024维)
# qwen/qwen3-embedding-0.6b (轻量, 1024维)
EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# LLM 模型
LLM_MODEL=qwen/qwen3-max

# 应用标识 (用于 OpenRouter 排行榜)
APP_NAME=SeekDB Agent Memory
APP_URL=https://github.com/yourusername/seekdb-agent-memory
