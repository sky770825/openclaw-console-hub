{
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "Bash(git *)",
      "Bash(npm run build*)",
      "Bash(node *)",
      "Bash(lsof *)",
      "Bash(bash scripts/*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/boot-chain.sh 2>/dev/null; exit 0"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/session-sync.sh 2>/dev/null; bash scripts/wake-sync.sh 2>/dev/null; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/post-push-sync.sh && bash scripts/notify-laocai.sh 'git push 完成' 'done' '已同步' 2>/dev/null; exit 0"
          }
        ]
      }
    ]
  }
}
