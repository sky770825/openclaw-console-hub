      "animate": { "opacity": 1, "y": 0 },
      "transition": { "duration": 0.5, "ease": "easeOut" }
    }
  },
  "visual_effects": [
    "Border Beam",
    "Background Grid (SVG)",
    "Masked Text Shimmer",
    "Ray Tracing Hover Effect"
  ]
