#!/bin/bash
# Password Manager Skill - Core Script
# Task ID: password-manager-skill-20260214

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KEYCHAIN_SERVICE="openclaw-password-manager"

show_usage() {
    cat << 'EOF'
Password Manager Skill - 安全密碼管理工具

Usage: password-manager <command> [options]

Commands:
    generate, g     生成強密碼
    store, s        儲存密碼到 Keychain
    retrieve, r     從 Keychain 取出密碼
    delete, d       從 Keychain 刪除密碼
    list, l         列出所有儲存的密碼項目
    check, c        檢查密碼強度
    help, h         顯示此幫助

generate options:
    -l, --length <n>      密碼長度 (預設: 16)
    -u, --uppercase       包含大寫字母 (預設: 啟用)
    -n, --no-uppercase    不包含大寫字母
    -d, --digits          包含數字 (預設: 啟用)
    -D, --no-digits       不包含數字
    -s, --special         包含特殊字符 (預設: 啟用)
    -S, --no-special      不包含特殊字符
    -e, --exclude <chars> 排除特定字符

store options:
    -a, --account <name>  帳號名稱 (必填)
    -p, --password <pwd>  密碼 (如不提供則提示輸入)
    -c, --comment <text>  備註說明

retrieve options:
    -a, --account <name>  帳號名稱 (必填)
    -c, --clipboard       複製到剪貼簿

delete options:
    -a, --account <name>  帳號名稱 (必填)
    -f, --force           不確認直接刪除

check options:
    -p, --password <pwd>  要檢查的密碼

Examples:
    password-manager generate -l 20
    password-manager store -a "github.com"
    password-manager retrieve -a "github.com" -c
    password-manager check -p "myPassword123"
EOF
}

generate_password() {
    local length=16
    local use_uppercase=true
    local use_lowercase=true
    local use_digits=true
    local use_special=true
    local exclude_chars=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            -l|--length) length="$2"; shift 2 ;;
            -u|--uppercase) use_uppercase=true; shift ;;
            -n|--no-uppercase) use_uppercase=false; shift ;;
            -d|--digits) use_digits=true; shift ;;
            -D|--no-digits) use_digits=false; shift ;;
            -s|--special) use_special=true; shift ;;
            -S|--no-special) use_special=false; shift ;;
            -e|--exclude) exclude_chars="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    
    if [[ ! "$length" =~ ^[0-9]+$ ]] || [[ "$length" -lt 4 ]]; then
        echo -e "${RED}Error: 密碼長度必須至少為 4${NC}"
        return 1
    fi
    
    local charset=""
    $use_lowercase && charset="${charset}abcdefghijklmnopqrstuvwxyz"
    $use_uppercase && charset="${charset}ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    $use_digits && charset="${charset}0123456789"
    $use_special && charset="${charset}!@#$%^&*()-_=+[]{}|;:,.<>?"
    
    if [[ -n "$exclude_chars" ]]; then
        for (( i=0; i<${#exclude_chars}; i++ )); do
            char="${exclude_chars:$i:1}"
            charset="${charset//$char/}"
        done
    fi
    
    if [[ -z "$charset" ]]; then
        echo -e "${RED}Error: 字符集為空${NC}"
        return 1
    fi
    
    local password=""
    local charset_length=${#charset}
    
    for (( i=0; i<length; i++ )); do
        local random_byte=$(od -An -N1 -i /dev/urandom | tr -d ' ')
        local index=$((random_byte % charset_length))
        password="${password}${charset:$index:1}"
    done
    
    echo "$password"
}

check_password_strength() {
    local password=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            -p|--password) password="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    
    if [[ -z "$password" ]]; then
        read -s -p "Enter password to check: " password
        echo
    fi
    
    local length=${#password}
    local score=0
    local feedback=()
    
    if [[ $length -ge 16 ]]; then
        score=$((score + 4))
    elif [[ $length -ge 12 ]]; then
        score=$((score + 3))
    elif [[ $length -ge 8 ]]; then
        score=$((score + 2))
        feedback+=("密碼長度建議至少 12 個字符")
    else
        score=$((score + 1))
        feedback+=("密碼太短，建議至少 12 個字符")
    fi
    
    local has_lowercase=false
    local has_uppercase=false
    local has_digit=false
    local has_special=false
    
    [[ "$password" =~ [a-z] ]] && has_lowercase=true && score=$((score + 1))
    [[ "$password" =~ [A-Z] ]] && has_uppercase=true && score=$((score + 1))
    [[ "$password" =~ [0-9] ]] && has_digit=true && score=$((score + 1))
    [[ "$password" =~ [^a-zA-Z0-9] ]] && has_special=true && score=$((score + 2))
    
    ! $has_lowercase && feedback+=("缺少小寫字母")
    ! $has_uppercase && feedback+=("缺少大寫字母")
    ! $has_digit && feedback+=("缺少數字")
    ! $has_special && feedback+=("缺少特殊字符")
    
    if [[ "$password" =~ (123|abc|qwerty|password|111|000|admin|login) ]]; then
        score=$((score - 2))
        feedback+=("包含常見弱密碼模式")
    fi
    
    [[ $score -lt 0 ]] && score=0
    [[ $score -gt 10 ]] && score=10
    
    echo -e "\n${BLUE}=== 密碼強度分析 ===${NC}"
    echo -e "長度: $length 字符"
    echo -ne "小寫: "; $has_lowercase && echo -e "${GREEN}✓${NC}" || echo -e "${RED}✗${NC}"
    echo -ne "大寫: "; $has_uppercase && echo -e "${GREEN}✓${NC}" || echo -e "${RED}✗${NC}"
    echo -ne "數字: "; $has_digit && echo -e "${GREEN}✓${NC}" || echo -e "${RED}✗${NC}"
    echo -ne "特殊: "; $has_special && echo -e "${GREEN}✓${NC}" || echo -e "${RED}✗${NC}"
    
    echo -ne "\n強度: "
    if [[ $score -ge 9 ]]; then
        echo -e "${GREEN}極強 ($score/10)${NC}"
    elif [[ $score -ge 7 ]]; then
        echo -e "${GREEN}強 ($score/10)${NC}"
    elif [[ $score -ge 5 ]]; then
        echo -e "${YELLOW}中等 ($score/10)${NC}"
    elif [[ $score -ge 3 ]]; then
        echo -e "${YELLOW}弱 ($score/10)${NC}"
    else
        echo -e "${RED}極弱 ($score/10)${NC}"
    fi
    
    if [[ ${#feedback[@]} -gt 0 ]]; then
        echo -e "\n${YELLOW}建議:${NC}"
        for item in "${feedback[@]}"; do echo "  • $item"; done
    fi
}

store_password() {
    local account=""
    local password=""
    local comment=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            -a|--account) account="$2"; shift 2 ;;
            -p|--password) password="$2"; shift 2 ;;
            -c|--comment) comment="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    
    if [[ -z "$account" ]]; then
        echo -e "${RED}Error: 請提供帳號名稱 (-a <account>)${NC}"
        return 1
    fi
    
    if [[ -z "$password" ]]; then
        read -s -p "Enter password: " password
        echo
        read -s -p "Confirm password: " password_confirm
        echo
        if [[ "$password" != "$password_confirm" ]]; then
            echo -e "${RED}Error: 密碼不匹配${NC}"
            return 1
        fi
    fi
    
    if security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$account" &>/dev/null; then
        echo -e "${YELLOW}Warning: 帳號 '$account' 已存在，將更新密碼${NC}"
        security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$account" &>/dev/null
    fi
    
    if [[ -n "$comment" ]]; then
        security add-generic-password -s "$KEYCHAIN_SERVICE" -a "$account" -w "$password" -j "$comment" -T "" -U
    else
        security add-generic-password -s "$KEYCHAIN_SERVICE" -a "$account" -w "$password" -T "" -U
    fi
    
    if [[ $? -eq 0 ]]; then
        echo -e "${GREEN}✓ 密碼已儲存到 Keychain${NC}"
        echo "  服務: $KEYCHAIN_SERVICE"
        echo "  帳號: $account"
    else
        echo -e "${RED}✗ 儲存失敗${NC}"
        return 1
    fi
}

retrieve_password() {
    local account=""
    local to_clipboard=false
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            -a|--account) account="$2"; shift 2 ;;
            -c|--clipboard) to_clipboard=true; shift ;;
            *) shift ;;
        esac
    done
    
    if [[ -z "$account" ]]; then
        echo -e "${RED}Error: 請提供帳號名稱 (-a <account>)${NC}"
        return 1
    fi
    
    local password=$(security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$account" -w 2>/dev/null)
    
    if [[ $? -ne 0 ]]; then
        echo -e "${RED}Error: 找不到帳號 '$account'${NC}"
        return 1
    fi
    
    if $to_clipboard; then
        echo "$password" | pbcopy
        echo -e "${GREEN}✓ 密碼已複製到剪貼簿 (30秒後清除)${NC}"
        (sleep 30 && echo "" | pbcopy) &
    else
        echo -e "${GREEN}密碼:${NC} $password"
    fi
}

delete_password() {
    local account=""
    local force=false
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            -a|--account) account="$2"; shift 2 ;;
            -f|--force) force=true; shift ;;
            *) shift ;;
        esac
    done
    
    if [[ -z "$account" ]]; then
        echo -e "${RED}Error: 請提供帳號名稱 (-a <account>)${NC}"
        return 1
    fi
    
    if ! $force; then
        read -p "確認刪除帳號 '$account' 的密碼? [y/N]: " confirm
        [[ "$confirm" != "y" && "$confirm" != "Y" ]] && return 0
    fi
    
    if security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$account" &>/dev/null; then
        echo -e "${GREEN}✓ 已刪除帳號 '$account'${NC}"
    else
        echo -e "${RED}✗ 刪除失敗或帳號不存在${NC}"
        return 1
    fi
}

list_passwords() {
    echo -e "${BLUE}=== 儲存的密碼項目 ===${NC}"
    local count=0
    
    # Get all password entries and filter for our service
    local entries
    entries=$(security dump-keychain 2>/dev/null | grep -E "(acct|svce)" | grep -B 1 "\"$KEYCHAIN_SERVICE\"" | grep "acct" | sed 's/.*"acct"<blob>="\(.*\)".*/\1/' || true)
    
    if [[ -z "$entries" ]]; then
        echo "  (無項目)"
    else
        while IFS= read -r account; do
            if [[ -n "$account" ]]; then
                echo "  • $account"
                count=$((count + 1))
            fi
        done <<< "$entries"
        echo ""
        echo "共 $count 個項目"
    fi
}

# Main
main() {
case "${1:-help}" in
    generate|g)
        shift
        pwd=$(generate_password "$@")
        printf "${GREEN}生成的密碼:${NC} %s\n" "$pwd"
        ;;
    check|c)
        shift
        check_password_strength "$@"
        ;;
    store|s)
        shift
        store_password "$@"
        ;;
    retrieve|r)
        shift
        retrieve_password "$@"
        ;;
    delete|d)
        shift
        delete_password "$@"
        ;;
    list|l)
        list_passwords
        ;;
    help|h|*)
        show_usage
        ;;
esac
}

main "$@"
