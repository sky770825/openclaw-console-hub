# OpenClaw TaskBoard Server Configuration

# Environment
PORT=3011
NODE_ENV=production

# [P0] Security: CORS
# Comma-separated list of allowed origins.
# Example: https://dashboard.openclaw.io,https://my-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# [P0] Security: Dashboard Basic Auth
# Required for accessing the dashboard and API endpoints.
OPENCLAW_DASHBOARD_BASIC_USER=admin
OPENCLAW_DASHBOARD_BASIC_PASS=generate_a_secure_password_here

# [P0] Security: API Key
# 32+ character strong random key for write operation validation (x-api-key header).
# Generated Example: c5b1bc0bd0edef801382ffa3a87cab901a5604d1cd8e74d9984cd77a55b46ddf
OPENCLAW_API_KEY=c5b1bc0bd0edef801382ffa3a87cab901a5604d1cd8e74d9984cd77a55b46ddf

# [P0] Security: Telegram
# MUST be set to false for production to prevent unauthorized chat access.
TELEGRAM_ALLOW_ANY_CHAT=false
